<UserControl x:Class="PulseMeter.Slices.AccountUsage.UI.AccountUsageSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PulseMeter.Slices.AccountUsage.UI">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Border x:Name="AccountUsageDashboard"
                                    Margin="0,12,0,0"
                                    Padding="16"
                                    Style="{DynamicResource LightCardStyle}"
                                    Visibility="{Binding DataContext.IsAccountUsageVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    ToolTip="{Binding TodayUsageValueText}">
                                <StackPanel>
                                    <Grid x:Name="DashboardHeader"
                                          MinHeight="36">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel x:Name="AccountUsageHeaderTitleGroup"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="ACCOUNT USAGE"
                                                       Foreground="#111827"
                                                       FontSize="20"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center" />
                                            <Border x:Name="AccountUsageEvidenceLabel"
                                                    Margin="10,0,0,0"
                                                    Style="{DynamicResource LightEvidencePillStyle}">
                                                <TextBlock Text="{Binding DataContext.SyncStatusText, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           Style="{DynamicResource LightEvidencePillTextStyle}" />
                                            </Border>
                                        </StackPanel>
                                        <StackPanel x:Name="AccountUsageRefreshControls"
                                                    Grid.Column="1"
                                                    HorizontalAlignment="Right"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Auto refresh every"
                                                       Foreground="#4B5563"
                                                       FontSize="13"
                                                       VerticalAlignment="Center" />
                                            <Grid Margin="10,0"
                                                  Width="82">
                                                <TextBox x:Name="AutoSyncSecondsTextBox"
                                                         HorizontalContentAlignment="Center"
                                                         VerticalContentAlignment="Center"
                                                         ToolTip="Enter 1 to 86,400 seconds. Press Enter to apply; press Escape to cancel."
                                                         AutomationProperties.Name="Auto refresh interval in seconds"
                                                         AutomationProperties.HelpText="Enter 1 to 86,400 seconds. Press Enter to apply; press Escape to cancel."
                                                         PreviewKeyDown="AutoSyncSecondsTextBox_OnPreviewKeyDown"
                                                         Style="{DynamicResource LightTextBoxStyle}">
                                                    <TextBox.Text>
                                                        <Binding Path="DataContext.AutoSyncSeconds"
                                                                 RelativeSource="{RelativeSource AncestorType=Window}"
                                                                 Mode="TwoWay"
                                                                 UpdateSourceTrigger="LostFocus">
                                                            <Binding.ValidationRules>
                                                                <local:AutoSyncSecondsValidationRule />
                                                            </Binding.ValidationRules>
                                                        </Binding>
                                                    </TextBox.Text>
                                                </TextBox>
                                                <TextBlock Margin="0,1,12,0"
                                                           Text="&#xE70F;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           Foreground="#4B5563"
                                                           FontSize="11"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           IsHitTestVisible="False" />
                                            </Grid>
                                            <TextBlock Text="seconds"
                                                       Foreground="#4B5563"
                                                       FontSize="13"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid x:Name="DashboardMetricCards"
                                          Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel x:Name="TodayMetricCard">
                                            <TextBlock Text="Today used tokens"
                                                       Foreground="#111827"
                                                       FontSize="14" />
                                            <TextBlock Margin="0,16,0,0"
                                                       Text="{Binding TodayUsageMetricValueText}"
                                                       Foreground="#111827"
                                                       FontSize="23"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="tokens"
                                                       Foreground="#111827"
                                                       FontSize="14" />
                                            <TextBlock Margin="0,10,0,0"
                                                       Text="{Binding TodayMedianDailyPercentText}"
                                                       Foreground="#4B5563"
                                                       FontSize="13" />
                                            <ProgressBar Width="112"
                                                         Height="5"
                                                         Margin="0,8,0,0"
                                                         HorizontalAlignment="Left"
                                                         Minimum="0"
                                                         Maximum="100"
                                                         Value="{Binding TodayMedianDailyPercentValue, Mode=OneWay}"
                                                         AutomationProperties.Name="{Binding TodayMedianDailyPercentText}"
                                                         Style="{DynamicResource LightProgressBarStyle}" />
                                        </StackPanel>

                                        <Border Grid.Column="1"
                                                Margin="0,0,0,0"
                                                Padding="16,0,0,0"
                                                BorderBrush="#E5E7EB"
                                                BorderThickness="1,0,0,0">
                                            <StackPanel x:Name="PeakMetricCard">
                                                <TextBlock Text="Peak day"
                                                           Foreground="#111827"
                                                           FontSize="14" />
                                                <TextBlock Margin="0,16,0,0"
                                                           Text="{Binding PeakUsageValueText}"
                                                           Foreground="#111827"
                                                           FontSize="23"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="tokens"
                                                           Foreground="#111827"
                                                           FontSize="14" />
                                                <TextBlock Margin="0,18,0,0"
                                                           Text="{Binding PeakUsageCaptionText}"
                                                           Foreground="#4B5563"
                                                           FontSize="13" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2"
                                                Padding="16,0,0,0"
                                                BorderBrush="#E5E7EB"
                                                BorderThickness="1,0,0,0">
                                            <StackPanel x:Name="LifetimeMetricCard">
                                                <TextBlock Text="Lifetime"
                                                           Foreground="#111827"
                                                           FontSize="14" />
                                                <TextBlock Margin="0,16,0,0"
                                                           Text="{Binding LifetimeUsageValueText}"
                                                           Foreground="#111827"
                                                           FontSize="23"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="tokens"
                                                           Foreground="#111827"
                                                           FontSize="14" />
                                                <TextBlock Margin="0,18,0,0"
                                                           Text="{Binding LifetimeUsageCaptionText}"
                                                           Foreground="#4B5563"
                                                           FontSize="13" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="3"
                                                Padding="16,0,0,0"
                                                BorderBrush="#E5E7EB"
                                                BorderThickness="1,0,0,0">
                                            <StackPanel x:Name="StreakMetricCard">
                                                <TextBlock Text="Streak"
                                                           Foreground="#111827"
                                                           FontSize="14" />
                                                <TextBlock Margin="0,16,0,0"
                                                           Text="{Binding StreakDaysValueText}"
                                                           Foreground="#111827"
                                                           FontSize="23"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="days"
                                                           Foreground="#111827"
                                                           FontSize="14" />
                                                <TextBlock Margin="0,18,0,0"
                                                           Text="{Binding StreakCaptionText}"
                                                           Foreground="#4B5563"
                                                           FontSize="13" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Border Margin="0,8,0,0"
                                            Padding="8,5"
                                            HorizontalAlignment="Center"
                                            Background="#FFFBEB"
                                            BorderBrush="#FDE68A"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Visibility="{Binding HasAccountSummaryFreshnessWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE7BA;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       Foreground="#B45309"
                                                       FontSize="11"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Margin="5,0,0,0"
                                                       Text="{Binding AccountSummaryFreshnessWarningText}"
                                                       Foreground="#92400E"
                                                       FontSize="11" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
</UserControl>
