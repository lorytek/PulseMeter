<UserControl x:Class="PulseMeter.Slices.NavigationRail.UI.NavigationRail"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:navModels="clr-namespace:PulseMeter.Slices.NavigationRail.Models">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="NavigationPanelToggleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="NavigationSectionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#F3F7FC" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Surface" Property="BorderBrush" Value="#1F73FF" />
                                <Setter TargetName="Surface" Property="BorderThickness" Value="1" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsNavigationPanelExpanded}" Value="False">
                                <Setter Property="Width" Value="42" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavigationItemContentStyle" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsNavigationPanelExpanded}" Value="False">
                    <Setter Property="HorizontalAlignment" Value="Center" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Width="{Binding NavigationPanelWidth}"
            Padding="14,28,14,20"
            Background="#FFFFFF"
            BorderBrush="#E5E7EB"
            BorderThickness="0,0,1,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Button HorizontalAlignment="Right"
                    Content="{Binding NavigationPanelToggleGlyph}"
                    ToolTip="{Binding NavigationPanelToggleTooltip}"
                    Click="NavigationPanelToggleButton_Click"
                    Style="{StaticResource NavigationPanelToggleButtonStyle}" />

            <StackPanel Grid.Row="1" Margin="0,28,0,0">
                <Button CommandParameter="{x:Static navModels:NavigationSection.Overview}"
                        ToolTip="Go to overview"
                        AutomationProperties.Name="Go to overview"
                        Click="SectionButton_Click"
                        Style="{StaticResource NavigationSectionButtonStyle}">
                    <StackPanel Style="{StaticResource NavigationItemContentStyle}">
                        <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="17" />
                        <TextBlock Margin="8,0,0,0" Text="Overview" FontSize="14" FontWeight="SemiBold"
                                   Visibility="{Binding IsNavigationPanelExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Button>

                <Button CommandParameter="{x:Static navModels:NavigationSection.RateLimits}"
                        ToolTip="Go to rate limits" AutomationProperties.Name="Go to rate limits"
                        Visibility="{Binding IsRateLimitsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Click="SectionButton_Click" Style="{StaticResource NavigationSectionButtonStyle}">
                    <StackPanel Style="{StaticResource NavigationItemContentStyle}">
                        <TextBlock Text="&#xE916;" FontFamily="Segoe MDL2 Assets" FontSize="17" />
                        <TextBlock Margin="8,0,0,0" Text="Rate limits" FontSize="13.5" Visibility="{Binding IsNavigationPanelExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Button>

                <Button CommandParameter="{x:Static navModels:NavigationSection.WeeklyPace}"
                        ToolTip="Go to weekly pace" AutomationProperties.Name="Go to weekly pace"
                        Visibility="{Binding IsRateLimitsDailyVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Click="SectionButton_Click" Style="{StaticResource NavigationSectionButtonStyle}">
                    <StackPanel Style="{StaticResource NavigationItemContentStyle}">
                        <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="17" />
                        <TextBlock Margin="8,0,0,0" Text="Weekly pace" FontSize="13.5" Visibility="{Binding IsNavigationPanelExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Button>

                <Button CommandParameter="{x:Static navModels:NavigationSection.RunwayForecast}"
                        ToolTip="Go to runway forecast" AutomationProperties.Name="Go to runway forecast"
                        Visibility="{Binding IsRunwayForecastVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Click="SectionButton_Click" Style="{StaticResource NavigationSectionButtonStyle}">
                    <StackPanel Style="{StaticResource NavigationItemContentStyle}">
                        <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="17" />
                        <TextBlock Margin="8,0,0,0" Text="Runway forecast" FontSize="13.5" Visibility="{Binding IsNavigationPanelExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Button>

                <Button CommandParameter="{x:Static navModels:NavigationSection.ResetCredits}"
                        ToolTip="Go to reset credits" AutomationProperties.Name="Go to reset credits"
                        Visibility="{Binding IsResetCreditsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Click="SectionButton_Click" Style="{StaticResource NavigationSectionButtonStyle}">
                    <StackPanel Style="{StaticResource NavigationItemContentStyle}">
                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="17" />
                        <TextBlock Margin="8,0,0,0" Text="Reset credits" FontSize="13.5" Visibility="{Binding IsNavigationPanelExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Button>

                <Button CommandParameter="{x:Static navModels:NavigationSection.AccountUsage}"
                        ToolTip="Go to account usage" AutomationProperties.Name="Go to account usage"
                        Visibility="{Binding IsAccountUsageVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Click="SectionButton_Click" Style="{StaticResource NavigationSectionButtonStyle}">
                    <StackPanel Style="{StaticResource NavigationItemContentStyle}">
                        <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="17" />
                        <TextBlock Margin="8,0,0,0" Text="Account usage" FontSize="13.5" Visibility="{Binding IsNavigationPanelExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Button>

                <Button CommandParameter="{x:Static navModels:NavigationSection.ProjectUsage}"
                        ToolTip="Go to project usage" AutomationProperties.Name="Go to project usage"
                        Visibility="{Binding IsProjectUsageVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Click="SectionButton_Click" Style="{StaticResource NavigationSectionButtonStyle}">
                    <StackPanel Style="{StaticResource NavigationItemContentStyle}">
                        <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="17" />
                        <TextBlock Margin="8,0,0,0" Text="Project usage" FontSize="13.5" Visibility="{Binding IsNavigationPanelExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Button>

                <Button CommandParameter="{x:Static navModels:NavigationSection.BurnAnalysis}"
                        ToolTip="Go to burn analysis" AutomationProperties.Name="Go to burn analysis"
                        Visibility="{Binding IsUsageAttributionVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Click="SectionButton_Click" Style="{StaticResource NavigationSectionButtonStyle}">
                    <StackPanel Style="{StaticResource NavigationItemContentStyle}">
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="17" />
                        <TextBlock Margin="8,0,0,0" Text="Burn analysis" FontSize="13.5" Visibility="{Binding IsNavigationPanelExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Button>

                <Button CommandParameter="{x:Static navModels:NavigationSection.DailyUsage}"
                        ToolTip="Go to daily usage" AutomationProperties.Name="Go to daily usage"
                        Visibility="{Binding IsDailyUsageVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Click="SectionButton_Click" Style="{StaticResource NavigationSectionButtonStyle}">
                    <StackPanel Style="{StaticResource NavigationItemContentStyle}">
                        <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="17" />
                        <TextBlock Margin="8,0,0,0" Text="Daily usage" FontSize="13.5" Visibility="{Binding IsNavigationPanelExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <Button x:Name="CustomizeDashboardButton"
                    Grid.Row="2"
                    Height="36"
                    Padding="8,0"
                    Background="#F8FAFC"
                    BorderBrush="#D9E0EA"
                    ToolTip="Choose visible sections"
                    AutomationProperties.Name="Choose visible sections"
                    Click="CustomizeDashboardButton_Click">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="15" />
                    <TextBlock Margin="8,0,0,0" Text="Customize" FontSize="13" Visibility="{Binding IsNavigationPanelExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </Button>

            <Popup x:Name="CustomizeDashboardPopup"
                   Placement="Right"
                   PlacementTarget="{Binding ElementName=CustomizeDashboardButton}"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   KeyDown="CustomizeDashboardPopup_KeyDown">
                <Border Width="220" Margin="8,0,0,0" Padding="14" Background="#FFFFFF" BorderBrush="#D9E0EA" BorderThickness="1" CornerRadius="6">
                    <StackPanel KeyboardNavigation.TabNavigation="Cycle">
                        <TextBlock Text="Visible sections" FontSize="14" FontWeight="SemiBold" Foreground="#111827" />
                        <CheckBox x:Name="RateLimitsVisibilityCheckBox" Margin="0,12,0,0" Content="Rate limits" IsChecked="{Binding IsRateLimitsVisible, Mode=TwoWay}" AutomationProperties.Name="Show rate limits" />
                        <CheckBox Margin="0,8,0,0" Content="Weekly pace" IsChecked="{Binding IsRateLimitsDailyVisible, Mode=TwoWay}" AutomationProperties.Name="Show weekly pace" />
                        <CheckBox Margin="0,8,0,0" Content="Runway forecast" IsChecked="{Binding IsRunwayForecastVisible, Mode=TwoWay}" AutomationProperties.Name="Show runway forecast" />
                        <CheckBox Margin="0,8,0,0" Content="Reset credits" IsChecked="{Binding IsResetCreditsVisible, Mode=TwoWay}" AutomationProperties.Name="Show reset credits" />
                        <CheckBox Margin="0,8,0,0" Content="Account usage" IsChecked="{Binding IsAccountUsageVisible, Mode=TwoWay}" AutomationProperties.Name="Show account usage" />
                        <CheckBox Margin="0,8,0,0" Content="Project usage" IsChecked="{Binding IsProjectUsageVisible, Mode=TwoWay}" AutomationProperties.Name="Show project usage" />
                        <CheckBox Margin="0,8,0,0" Content="Burn analysis" IsChecked="{Binding IsUsageAttributionVisible, Mode=TwoWay}" AutomationProperties.Name="Show burn analysis" />
                        <CheckBox Margin="0,8,0,0" Content="Daily usage" IsChecked="{Binding IsDailyUsageVisible, Mode=TwoWay}" AutomationProperties.Name="Show daily usage" />
                        <Button Margin="0,14,0,0" Padding="8,5" HorizontalAlignment="Left" Content="Reset to defaults" Click="ResetVisibility_Click" />
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>
