<UserControl x:Class="PulseMeter.Slices.DataBar.UI.DataBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Viewbox x:Name="CompactHeaderScaleBox"
             Stretch="Uniform"
             StretchDirection="DownOnly">
        <Viewbox.Style>
            <Style TargetType="Viewbox">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                        <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Viewbox.Style>
        <Grid x:Name="CompactHeaderGrid"
              Width="382"
              Height="52">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="93" />
            </Grid.ColumnDefinitions>

            <Viewbox x:Name="CompactQuotaScaleBox"
                     Grid.Row="0"
                     Grid.Column="0"
                     Stretch="Uniform"
                     StretchDirection="DownOnly"
                     VerticalAlignment="Center">
                <ItemsControl x:Name="CompactQuotaSummaryItemsControl"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Left"
                              AlternationCount="10"
                              ItemsSource="{Binding CompactQuotaRows}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Border x:Name="CompactQuotaSeparatorLine"
                                        Width="1"
                                        Height="34"
                                        Margin="12,0"
                                        VerticalAlignment="Center"
                                        Background="#E5E7EB"
                                        Visibility="{Binding ShowCompactSeparator, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <StackPanel VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Label}"
                                                   Foreground="#374151"
                                                   FontFamily="Segoe UI"
                                                   FontSize="13"
                                                   VerticalAlignment="Center" />
                                        <Ellipse Width="6"
                                                 Height="6"
                                                 Margin="5,1,5,0"
                                                 VerticalAlignment="Center"
                                                 Fill="{Binding RingBrush}" />
                                        <TextBlock Text="{Binding CompactRemainingPercentText}"
                                                   Foreground="#374151"
                                                   FontFamily="Segoe UI"
                                                   FontSize="13"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Margin="0,3,0,0"
                                                Orientation="Horizontal">
                                        <TextBlock Text="Resets "
                                                   Foreground="#6B7280"
                                                   FontFamily="Segoe UI"
                                                   FontSize="10.5" />
                                        <TextBlock Text="{Binding ResetDisplayText}"
                                                   Foreground="#6B7280"
                                                   FontFamily="Segoe UI"
                                                   FontSize="10.5" />
                                    </StackPanel>
                                    <Border x:Name="CompactQuotaAccentLine"
                                            Height="1"
                                            Margin="0,3,0,0"
                                            Background="{Binding RingBrush}"
                                            Opacity="0.45" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Viewbox>

            <StackPanel x:Name="CompactStatusIndicator"
                        Grid.Row="0"
                        Grid.Column="1"
                        Margin="12,0,0,0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Border Width="8"
                        Height="8"
                        Margin="0,0,6,0"
                        VerticalAlignment="Center"
                        Background="#28B946"
                        CornerRadius="4" />
                <TextBlock Text="{Binding StatusBadgeText}"
                           Foreground="#16A34A"
                           FontSize="13"
                           VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel x:Name="CompactHeaderControls"
                        Grid.Row="0"
                        Grid.Column="2"
                        Margin="12,0,0,0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Border Width="1"
                        Height="32"
                        Margin="0,0,12,0"
                        Background="#E5E7EB" />
                <Button Style="{DynamicResource CompactIconButtonStyle}"
                        ToolTip="{Binding ExpandCollapseTooltip}"
                        Click="ExpandCollapseButton_Click">
                    <Path Width="12"
                          Height="8"
                          Stroke="#111827"
                          StrokeThickness="1.6"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Data="M 1 1 L 6 7 L 11 1" />
                </Button>
                <Button Margin="8,0,0,0"
                        Style="{DynamicResource CompactIconButtonStyle}"
                        ToolTip="Hide PulseMeter"
                        Click="HideButton_Click">
                    <Path Width="12"
                          Height="12"
                          Stroke="#111827"
                          StrokeThickness="1.6"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Data="M 1 1 L 11 11 M 11 1 L 1 11" />
                </Button>
            </StackPanel>
        </Grid>
    </Viewbox>
</UserControl>
