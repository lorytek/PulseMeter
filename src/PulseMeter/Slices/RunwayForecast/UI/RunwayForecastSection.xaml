<UserControl x:Class="PulseMeter.Slices.RunwayForecast.UI.RunwayForecastSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Border x:Name="RunwayForecastPanel"
            Margin="0,12,0,0"
            Padding="16"
            Style="{DynamicResource LightCardStyle}"
            Visibility="{Binding DataContext.IsRunwayForecastVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="RUNWAY FORECAST"
                           Foreground="#111827"
                           FontSize="20"
                           FontWeight="Bold" />
                <Border Margin="10,2,0,0"
                        Style="{DynamicResource LightEvidencePillStyle}">
                    <TextBlock Text="Estimated"
                               Style="{DynamicResource LightEvidencePillTextStyle}" />
                </Border>
                <Border Margin="6,2,0,0"
                        Style="{DynamicResource LightEvidencePillStyle}">
                    <TextBlock Text="Recent pace"
                               Style="{DynamicResource LightEvidencePillTextStyle}" />
                </Border>
            </StackPanel>

            <TextBlock Margin="0,6,0,0"
                       Text="Short-term projection from recent rate-limit movement"
                       Foreground="#6B7280"
                       FontSize="13" />

            <TextBlock Margin="0,14,0,0"
                       Text="{Binding EmptyStateText}"
                       Foreground="#4B5563"
                       FontSize="13">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasRows}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Grid Margin="0,16,0,0"
                  Visibility="{Binding HasRows, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="88" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="160" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Window" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="Now" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold" />
                <TextBlock Grid.Column="2" Text="Forecast" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold" />
                <TextBlock Grid.Column="3" Text="Reset" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Right" />
            </Grid>
            <Border Height="1" Margin="0,6,0,0" Background="#E5E7EB"
                    Visibility="{Binding HasRows, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <ItemsControl ItemsSource="{Binding Rows}"
                          Visibility="{Binding HasRows, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid MinHeight="66" ToolTip="{Binding TooltipText}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="88" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="160" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="1" />
                            </Grid.RowDefinitions>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding TrackText}" Foreground="#111827" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding WindowText}" Foreground="#6B7280" FontSize="11.5" TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <TextBlock Grid.Column="1" Text="{Binding RemainingText}" Foreground="#111827" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />

                            <StackPanel Grid.Column="2" Margin="0,8,12,8" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <Border Padding="7,2" Background="{Binding StatusBackground}" BorderBrush="{Binding StatusBorder}" BorderThickness="1" CornerRadius="5">
                                        <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusForeground}" FontSize="10.5" FontWeight="SemiBold" />
                                    </Border>
                                    <TextBlock Margin="8,0,0,0" Text="{Binding ForecastText}" Foreground="#111827" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding DetailText}"
                                           Foreground="#4B5563"
                                           FontSize="11.5"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,2,0,0" Text="{Binding EvidenceText}" Foreground="#6B7280" FontSize="10.5" TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <StackPanel Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ResetText}" Foreground="#111827" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                <TextBlock Text="{Binding ResetCountdownText}" Foreground="#6B7280" FontSize="11.5" HorizontalAlignment="Right" />
                            </StackPanel>

                            <Border Grid.Row="1" Grid.ColumnSpan="4" Background="#E5E7EB" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
