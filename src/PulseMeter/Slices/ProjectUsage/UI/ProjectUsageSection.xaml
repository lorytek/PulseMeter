<UserControl x:Class="PulseMeter.Slices.ProjectUsage.UI.ProjectUsageSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Border x:Name="ProjectUsagePanel"
                                    Margin="0,12,0,0"
                                    Padding="16"
                                    Style="{DynamicResource LightCardStyle}"
                                    Visibility="{Binding DataContext.ShouldShowProjectUsage, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text="Project usage - last 30 days"
                                                       Foreground="#111827"
                                                       FontSize="20"
                                                       FontWeight="Bold" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Text="Estimated from local sessions, scaled to account usage"
                                                       Foreground="#4B5563"
                                                       FontSize="14" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="96" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Project"
                                                   Foreground="#374151"
                                                   FontSize="14" />
                                        <TextBlock Grid.Column="2"
                                                   Text="Share"
                                                   Foreground="#374151"
                                                   FontSize="14" />
                                        <TextBlock Grid.Column="3"
                                                   Text="Estimate"
                                                   Foreground="#374151"
                                                   FontSize="14" />
                                    </Grid>
                                    <Border Height="1"
                                            Margin="0,13,0,0"
                                            Background="#E5E7EB" />

                                    <ItemsControl ItemsSource="{Binding ProjectUsageRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid MinHeight="38"
                                                      ToolTip="{Binding FullPath}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="220" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="92" />
                                                        <ColumnDefinition Width="96" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*" />
                                                        <RowDefinition Height="1" />
                                                    </Grid.RowDefinitions>

                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Foreground="#111827"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>

                                                    <ProgressBar Grid.Column="1"
                                                                 Height="6"
                                                                 Margin="12,0,18,0"
                                                                 HorizontalAlignment="Stretch"
                                                                 Minimum="0"
                                                                 Maximum="100"
                                                                 Value="{Binding SharePercentValue, Mode=OneWay}"
                                                                 Style="{DynamicResource LightProgressBarStyle}"
                                                                 VerticalAlignment="Center" />

                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding ShareText}"
                                                               Foreground="#111827"
                                                               FontSize="14"
                                                               VerticalAlignment="Center" />

                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding EstimatedTokensText}"
                                                               Foreground="#111827"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center" />

                                                    <Border Grid.Row="1"
                                                            Grid.ColumnSpan="4"
                                                            Background="#E5E7EB" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
</UserControl>
