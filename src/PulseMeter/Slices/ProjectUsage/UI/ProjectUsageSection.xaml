<UserControl x:Class="PulseMeter.Slices.ProjectUsage.UI.ProjectUsageSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shared="clr-namespace:PulseMeter.Shared.UI">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="ProjectHealthRowStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#F8FAFC" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EFF6FF" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#1F73FF" />
                                <Setter TargetName="ItemBorder" Property="BorderThickness" Value="3,0,0,0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border x:Name="ProjectUsagePanel"
            Margin="0,12,0,0"
            Padding="16"
            Style="{DynamicResource LightCardStyle}"
            Visibility="{Binding DataContext.ShouldShowProjectUsage, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="PROJECT HEALTH"
                           Foreground="#111827"
                           FontSize="20"
                           FontWeight="Bold" />
                <Border x:Name="ProjectUsageEstimatedEvidenceLabel"
                        Style="{DynamicResource LightEvidencePillStyle}">
                    <TextBlock Text="Estimated"
                               Style="{DynamicResource LightEvidencePillTextStyle}" />
                </Border>
                <Border x:Name="ProjectUsageLocalEvidenceLabel"
                        Margin="6,2,0,0"
                        Style="{DynamicResource LightEvidencePillStyle}">
                    <TextBlock Text="Local"
                               Style="{DynamicResource LightEvidencePillTextStyle}" />
                </Border>
            </StackPanel>
            <TextBlock Margin="0,8,0,0"
                       Text="Estimated from local sessions, scaled to account usage"
                       Foreground="#4B5563"
                       FontSize="14" />

            <Border Margin="0,16,0,0"
                    Padding="4,12"
                    Background="#FAFCFE"
                    BorderBrush="#E5E7EB"
                    BorderThickness="0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="34" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="54" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="&#x2197;"
                               FontFamily="Segoe UI Symbol"
                               Foreground="#D97706"
                               FontSize="28"
                               VerticalAlignment="Center"
                               AutomationProperties.Name="Largest increase" />
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="Largest 7-day increase"
                                   Foreground="#6B7280"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                        <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                            <TextBlock Text="{Binding LargestIncreaseProjectText}"
                                       Foreground="#111827"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Margin="8,0,0,0"
                                       Text="{Binding LargestIncreaseValueText}"
                                       Foreground="#D97706"
                                       FontSize="14"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </StackPanel>
                    <Border Grid.Column="2" Background="#E5E7EB" />
                    <TextBlock Grid.Column="3"
                               Margin="20,0,0,0"
                               Text="&#x2198;"
                               FontFamily="Segoe UI Symbol"
                               Foreground="#16A34A"
                               FontSize="28"
                               VerticalAlignment="Center"
                               AutomationProperties.Name="Largest drop" />
                    <StackPanel Grid.Column="4" Margin="8,0,0,0">
                        <TextBlock Text="Largest 7-day drop"
                                   Foreground="#6B7280"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                        <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                            <TextBlock Text="{Binding LargestDropProjectText}"
                                       Foreground="#111827"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Margin="8,0,0,0"
                                       Text="{Binding LargestDropValueText}"
                                       Foreground="#16A34A"
                                       FontSize="14"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="152" />
                    <ColumnDefinition Width="86" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="88" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Project" Foreground="#6B7280" FontSize="12" FontWeight="SemiBold" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="30d share"
                               ToolTip="This project's share of all locally attributed token usage in the last 30 days."
                               Foreground="#6B7280"
                               FontSize="12"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="4,0,0,0"
                               Text="&#xE946;"
                               ToolTip="This project's share of all locally attributed token usage in the last 30 days."
                               Foreground="#9CA3AF"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="10"
                               VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Grid.Column="2"
                           Text="Last 7d"
                           ToolTip="Estimated tokens attributed to this project in the last 7 days."
                           Foreground="#6B7280"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextAlignment="Right" />
                <TextBlock Grid.Column="3"
                           Text="vs prior 7d"
                           ToolTip="Difference between the last 7 days and the 7 days before that."
                           Foreground="#6B7280"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextAlignment="Right" />
                <TextBlock Grid.Column="4"
                           Text="Last 30d"
                           ToolTip="Estimated tokens attributed to this project in the last 30 days."
                           Foreground="#6B7280"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextAlignment="Right" />
            </Grid>
            <Border Height="1" Margin="0,8,0,0" Background="#E5E7EB" />

            <ListBox ItemsSource="{Binding ProjectUsageRows}"
                     SelectedItem="{Binding SelectedProjectRow, Mode=TwoWay}"
                     BorderThickness="0"
                     Background="Transparent"
                     shared:MouseWheelScrollRelay.RelayToParent="True"
                     ItemContainerStyle="{StaticResource ProjectHealthRowStyle}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid MinHeight="52" ToolTip="{Binding FullPath}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="152" />
                                <ColumnDefinition Width="86" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="88" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="1" />
                            </Grid.RowDefinitions>
                            <StackPanel Margin="12,4,8,4" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}"
                                           Foreground="#111827"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <Grid Grid.Column="1" Margin="4,0,12,0" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="42" />
                                </Grid.ColumnDefinitions>
                                <ProgressBar Height="6"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="{Binding SharePercentValue, Mode=OneWay}"
                                             Style="{DynamicResource LightProgressBarStyle}"
                                             VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ShareText}"
                                           Foreground="#4B5563"
                                           FontSize="12"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center" />
                            </Grid>
                            <TextBlock Grid.Column="2" Margin="4,0" Text="{Binding Last7DaysText}" Foreground="#111827" FontSize="13" FontWeight="SemiBold" TextAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Margin="4,0" Text="{Binding TrendText}" Foreground="{Binding TrendBrush}" FontSize="13" FontWeight="SemiBold" TextAlignment="Right" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="4" Margin="4,0,8,0" Text="{Binding EstimatedTokensText}" Foreground="#111827" FontSize="13" FontWeight="SemiBold" TextAlignment="Right" VerticalAlignment="Center" />
                            <Border Grid.Row="1" Grid.ColumnSpan="5" Background="#E5E7EB" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Height="1" Margin="0,10,0,0" Background="#E5E7EB" />
            <StackPanel Margin="0,12,0,0">
                <TextBlock Text="SELECTED PROJECT" Foreground="#6B7280" FontSize="12" FontWeight="SemiBold" />
                <TextBlock Margin="0,5,0,0" Text="{Binding SelectedProjectTitle}" Foreground="#111827" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                <TextBlock Margin="0,3,0,0" Text="{Binding SelectedProjectSummary}" Foreground="#4B5563" FontSize="13" TextWrapping="Wrap" />
                <TextBlock Margin="0,7,0,0" Text="{Binding SelectedProjectChatsText}" Foreground="#374151" FontSize="13" TextTrimming="CharacterEllipsis" />
                <TextBlock Margin="0,3,0,0" Text="{Binding SelectedProjectMomentText}" Foreground="#374151" FontSize="13" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
