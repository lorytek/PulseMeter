<UserControl x:Class="PulseMeter.Slices.NeedsAttention.UI.NeedsAttentionSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Border x:Name="NeedsAttentionPanel"
            Margin="0,12,0,0"
            Padding="16"
            Style="{DynamicResource LightCardStyle}">
        <StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="NEEDS ATTENTION"
                           Foreground="#111827"
                           FontSize="20"
                           FontWeight="Bold" />
                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <TextBlock x:Name="CopyFeedbackTextBlock"
                               Margin="0,0,12,0"
                               VerticalAlignment="Center"
                               Text="{Binding CopyFeedbackText, NotifyOnTargetUpdated=True}"
                               Foreground="{Binding CopyFeedbackBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               AutomationProperties.LiveSetting="Polite"
                               TargetUpdated="CopyFeedbackText_OnTargetUpdated"
                               Visibility="{Binding HasCopyFeedback, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock VerticalAlignment="Center"
                               Text="{Binding NeedsAttentionSummaryText}"
                               Foreground="#4B5563"
                               FontSize="13" />
                    <Button x:Name="ToggleAttentionItemsButton"
                            Margin="12,0,0,0"
                            Padding="8,4"
                            VerticalAlignment="Center"
                            Content="{Binding ToggleAttentionItemsText}"
                            Command="{Binding ToggleAttentionItemsCommand}"
                            ToolTip="{Binding ToggleAttentionItemsAccessibleLabel}"
                            AutomationProperties.Name="{Binding ToggleAttentionItemsAccessibleLabel}"
                            FontSize="12"
                            Style="{DynamicResource LightButtonStyle}"
                            Visibility="{Binding HasHiddenAttentionItems, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </Grid>

            <Border Margin="0,12,0,0"
                    Padding="10,7"
                    Background="#EFF6FF"
                    BorderBrush="#BFDBFE"
                    BorderThickness="1"
                    CornerRadius="6"
                    Visibility="{Binding HasPendingDismissal, Converter={StaticResource BooleanToVisibilityConverter}}">
                <DockPanel LastChildFill="True">
                    <Button DockPanel.Dock="Right"
                            Margin="12,0,0,0"
                            Padding="10,4"
                            Content="Undo"
                            Command="{Binding UndoDismissCommand}"
                            ToolTip="Restore dismissed idle alert"
                            AutomationProperties.Name="Undo dismissed idle alert"
                            FontSize="12"
                            Style="{DynamicResource LightButtonStyle}" />
                    <TextBlock x:Name="DismissUndoTextBlock"
                               VerticalAlignment="Center"
                               Text="{Binding DismissUndoText, NotifyOnTargetUpdated=True}"
                               Foreground="#1E3A8A"
                               FontSize="13"
                               FontWeight="SemiBold"
                               AutomationProperties.LiveSetting="Polite"
                               TargetUpdated="CopyFeedbackText_OnTargetUpdated" />
                </DockPanel>
            </Border>

            <StackPanel Margin="0,14,0,0"
                        Orientation="Horizontal">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasNeedsAttention}" Value="False">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <Ellipse Width="10"
                         Height="10"
                         Margin="0,3,10,0"
                         Fill="#22C55E" />
                <TextBlock Text="All clear - no items need attention right now."
                           Foreground="#4B5563"
                           FontSize="14" />
            </StackPanel>

            <ItemsControl Margin="0,14,0,0"
                          ItemsSource="{Binding VisibleNeedsAttentionItems}">
                <ItemsControl.Style>
                    <Style TargetType="ItemsControl">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasNeedsAttention}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ItemsControl.Style>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid MinHeight="48">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="76" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="1" />
                            </Grid.RowDefinitions>

                            <Border Width="62"
                                    Height="24"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="#F9FAFB"
                                    BorderBrush="{Binding AccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <TextBlock Text="{Binding BadgeText}"
                                           Foreground="#111827"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1"
                                        Margin="0,6,12,6"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}"
                                           Foreground="#111827"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Margin="0,3,0,0"
                                           Text="{Binding Detail}"
                                           Foreground="#4B5563"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding HasDetail, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>

                            <StackPanel x:Name="ActionPanel"
                                        Grid.Column="2"
                                        Margin="0,6,0,6"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding HasActions, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Button Padding="10,5"
                                        Content="Copy"
                                        ToolTip="{Binding CopyAccessibleLabel}"
                                        AutomationProperties.Name="{Binding CopyAccessibleLabel}"
                                        Command="{Binding DataContext.CopyDiagnosticCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        FontSize="12"
                                        Style="{DynamicResource LightButtonStyle}"
                                        Visibility="{Binding CanCopyDiagnostic, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button Margin="6,0,0,0"
                                        Padding="10,5"
                                        Content="Dismiss"
                                        ToolTip="Dismiss idle alert"
                                        AutomationProperties.Name="Dismiss idle alert"
                                        Command="{Binding DataContext.DismissSignalCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        FontSize="12"
                                        Style="{DynamicResource LightButtonStyle}"
                                        Visibility="{Binding CanDismiss, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button Margin="6,0,0,0"
                                        Padding="10,5"
                                        Content="Review"
                                        ToolTip="{Binding ReviewAccessibleLabel}"
                                        AutomationProperties.Name="{Binding ReviewAccessibleLabel}"
                                        Click="ReviewButton_Click"
                                        FontSize="12"
                                        Style="{DynamicResource LightButtonStyle}"
                                        Visibility="{Binding CanReview, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Grid.ColumnSpan="3"
                                    Background="#E5E7EB" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button x:Name="CollapseAttentionItemsButton"
                    Margin="0,12,0,0"
                    Padding="10,5"
                    HorizontalAlignment="Right"
                    Content="Show top 3"
                    Command="{Binding ToggleAttentionItemsCommand}"
                    Click="CollapseAttentionItemsButton_Click"
                    IsVisibleChanged="CollapseAttentionItemsButton_IsVisibleChanged"
                    ToolTip="Show top 3 attention signals"
                    AutomationProperties.Name="Show top 3 attention signals"
                    FontSize="12"
                    Style="{DynamicResource LightButtonStyle}"
                    Visibility="{Binding IsShowingAll, Converter={StaticResource BooleanToVisibilityConverter}}" />

        </StackPanel>
    </Border>
</UserControl>
