<UserControl x:Class="PulseMeter.Slices.ExpandedHeader.UI.ExpandedHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border x:Name="ExpandedStickyHeader"
            Padding="24,32,30,16"
            Background="#FFFFFF"
            BorderBrush="#E5E7EB"
            BorderThickness="0,0,0,1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Border x:Name="ExpandedHeaderLogo"
                        Width="26"
                        Height="26"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        SnapsToDevicePixels="True">
                    <Border.Background>
                        <ImageBrush ImageSource="/Assets/PulseMeterLogo.png"
                                    Stretch="UniformToFill"
                                    Viewbox="0.38,0.31,0.20,0.26"
                                    ViewboxUnits="RelativeToBoundingBox" />
                    </Border.Background>
                </Border>
                <TextBlock Text="{Binding CompactTitleText}"
                           Foreground="#111827"
                           FontSize="24"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Width="10"
                            Height="10"
                            VerticalAlignment="Center"
                            Background="#28B946"
                            CornerRadius="5" />
                    <TextBlock Margin="8,0,18,0"
                               Text="{Binding StatusBadgeText}"
                               Foreground="#111827"
                               FontSize="13"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Button Height="40"
                        Margin="0,0,8,0"
                        Command="{Binding SyncNowCommand}"
                        Style="{DynamicResource LightButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="15"
                                   VerticalAlignment="Center" />
                        <TextBlock Margin="9,0,0,0"
                                   Text="Sync"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Content="&#xE70E;"
                        Click="ExpandCollapseButton_Click"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="13"
                        Style="{DynamicResource LightIconButtonStyle}"
                        ToolTip="{Binding ExpandCollapseTooltip}" />
                <Button Margin="8,0,0,0"
                        Click="HideButton_Click"
                        Style="{DynamicResource LightIconButtonStyle}"
                        ToolTip="Hide PulseMeter">
                    <Path Width="12"
                          Height="12"
                          Stroke="#111827"
                          StrokeThickness="1.6"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Data="M 1 1 L 11 11 M 11 1 L 1 11" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
