<Window x:Class="PulseMeter.Slices.PulseMeterWindow.UI.PulseMeterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:accountUsage="clr-namespace:PulseMeter.Slices.AccountUsage.UI"
        xmlns:dailyUsage="clr-namespace:PulseMeter.Slices.DailyUsage.UI"
        xmlns:dataBar="clr-namespace:PulseMeter.Slices.DataBar.UI"
        xmlns:expandedHeader="clr-namespace:PulseMeter.Slices.ExpandedHeader.UI"
        xmlns:navigationRail="clr-namespace:PulseMeter.Slices.NavigationRail.UI"
        xmlns:needsAttention="clr-namespace:PulseMeter.Slices.NeedsAttention.UI"
        xmlns:projectUsage="clr-namespace:PulseMeter.Slices.ProjectUsage.UI"
        xmlns:rateLimits="clr-namespace:PulseMeter.Slices.RateLimits.UI"
        xmlns:rateLimitsDaily="clr-namespace:PulseMeter.Slices.RateLimitsDaily.UI"
        xmlns:resetCredits="clr-namespace:PulseMeter.Slices.ResetCredits.UI"
        xmlns:usageAttribution="clr-namespace:PulseMeter.Slices.UsageAttribution.UI"
        Title="PulseMeter"
        Width="{Binding WindowWidth}"
        Height="{Binding WindowHeight}"
        MinWidth="{Binding WindowMinWidth}"
        MinHeight="{Binding WindowMinHeight}"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        Topmost="{Binding IsAlwaysOnTop}"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="/Assets/PulseMeter.ico"
        SizeChanged="Window_SizeChanged">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Shared/Styles/PulseMeterControls.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </Window.Resources>
    <Border x:Name="WindowSurface"
            ClipToBounds="True"
            BorderThickness="1">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="#FFFFFF" />
                <Setter Property="BorderBrush" Value="#E5E7EB" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="14,6,12,6" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                        <Setter Property="Background" Value="#FFFFFF" />
                        <Setter Property="BorderBrush" Value="#E5E7EB" />
                        <Setter Property="CornerRadius" Value="6" />
                        <Setter Property="Padding" Value="0" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <dataBar:DataBar Grid.Row="0"
                             DataContext="{Binding DataBar}"
                             ToggleExpandedRequested="ExpandCollapseButton_Click"
                             HideRequested="HideButton_Click" />

            <Grid Grid.Row="1"
                  Background="#FFFFFF"
                  Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.LayoutTransform>
                    <ScaleTransform ScaleX="{Binding ExpandedLayoutScale}"
                                    ScaleY="{Binding ExpandedLayoutScale}" />
                </Grid.LayoutTransform>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <navigationRail:NavigationRail Grid.Column="0"
                                                   DataContext="{Binding NavigationRail}" />

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <expandedHeader:ExpandedHeader Grid.Row="0"
                                                       DataContext="{Binding ExpandedHeader}"
                                                       ToggleExpandedRequested="ExpandCollapseButton_Click"
                                                       HideRequested="HideButton_Click" />

                        <ScrollViewer x:Name="ExpandedContentScrollViewer"
                                      Grid.Row="1"
                                      VerticalScrollBarVisibility="Hidden"
                                      HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="24,14,30,28">
                            <rateLimits:RateLimitsSection DataContext="{Binding RateLimits}" />

                            <rateLimitsDaily:RateLimitsDailySection DataContext="{Binding RateLimitsDaily}" />

                            <resetCredits:ResetCreditsSection DataContext="{Binding ResetCreditsSection}" />

                            <accountUsage:AccountUsageSection DataContext="{Binding AccountUsage}" />

                            <projectUsage:ProjectUsageSection DataContext="{Binding ProjectUsage}" />

                            <usageAttribution:UsageAttributionSection DataContext="{Binding UsageAttribution}" />

                            <dailyUsage:DailyUsageSection DataContext="{Binding DailyUsage}" />

                            <needsAttention:NeedsAttentionSection DataContext="{Binding NeedsAttention}" />
                        </StackPanel>
                    </ScrollViewer>
                    </Grid>
                </Grid>
        </Grid>
    </Border>
</Window>
