<Window x:Class="PulseMeter.Slices.PulseMeterWindow.UI.PulseMeterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:accountUsage="clr-namespace:PulseMeter.Slices.AccountUsage.UI"
        xmlns:dailyUsage="clr-namespace:PulseMeter.Slices.DailyUsage.UI"
        xmlns:dataBar="clr-namespace:PulseMeter.Slices.DataBar.UI"
        xmlns:expandedHeader="clr-namespace:PulseMeter.Slices.ExpandedHeader.UI"
        xmlns:navigationRail="clr-namespace:PulseMeter.Slices.NavigationRail.UI"
        xmlns:needsAttention="clr-namespace:PulseMeter.Slices.NeedsAttention.UI"
        xmlns:projectUsage="clr-namespace:PulseMeter.Slices.ProjectUsage.UI"
        xmlns:rateLimits="clr-namespace:PulseMeter.Slices.RateLimits.UI"
        xmlns:rateLimitsDaily="clr-namespace:PulseMeter.Slices.RateLimitsDaily.UI"
        xmlns:resetCredits="clr-namespace:PulseMeter.Slices.ResetCredits.UI"
        xmlns:usageAttribution="clr-namespace:PulseMeter.Slices.UsageAttribution.UI"
        xmlns:usageTrend="clr-namespace:PulseMeter.Slices.UsageTrend.UI"
        Title="PulseMeter"
        Width="{Binding WindowWidth}"
        Height="{Binding WindowHeight}"
        MinWidth="{Binding WindowMinWidth}"
        MinHeight="{Binding WindowMinHeight}"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        Topmost="{Binding IsAlwaysOnTop}"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="/PulseMeter;component/Assets/PulseMeter.ico"
        SizeChanged="Window_SizeChanged">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/PulseMeter;component/Shared/Styles/PulseMeterControls.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </Window.Resources>
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding SyncNowCommand}" />
    </Window.InputBindings>
    <Border x:Name="WindowSurface"
            ClipToBounds="True"
            BorderThickness="1">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="#FFFFFF" />
                <Setter Property="BorderBrush" Value="#008CBA" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="14,6,12,6" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                        <Setter Property="Background" Value="#FFFFFF" />
                        <Setter Property="BorderBrush" Value="#E5E7EB" />
                        <Setter Property="CornerRadius" Value="6" />
                        <Setter Property="Padding" Value="0" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <dataBar:DataBar Grid.Row="0"
                             DataContext="{Binding DataBar}"
                             ToggleExpandedRequested="ExpandCollapseButton_Click"
                             HideRequested="HideButton_Click" />

            <Grid Grid.Row="1"
                  Background="#FFFFFF"
                  Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.LayoutTransform>
                    <ScaleTransform ScaleX="{Binding ExpandedLayoutScale}"
                                    ScaleY="{Binding ExpandedLayoutScale}" />
                </Grid.LayoutTransform>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <navigationRail:NavigationRail Grid.Column="0"
                                                   DataContext="{Binding NavigationRail}"
                                                   SectionRequested="NavigationRail_SectionRequested" />

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <expandedHeader:ExpandedHeader Grid.Row="0"
                                                       DataContext="{Binding ExpandedHeader}"
                                                       ToggleExpandedRequested="ExpandCollapseButton_Click"
                                                       HideRequested="HideButton_Click" />

                        <Border x:Name="SyncIssueBanner"
                                Grid.Row="1"
                                Margin="24,12,30,0"
                                Padding="12,10"
                                Background="{Binding SyncIssueBackground}"
                                BorderBrush="{Binding SyncIssueBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                AutomationProperties.LiveSetting="Assertive"
                                AutomationProperties.Name="{Binding SyncIssueAccessibleLabel}"
                                Visibility="{Binding HasActionableSyncIssue, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="&#xE7BA;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="15"
                                           Foreground="{Binding SyncIssueForeground}"
                                           VerticalAlignment="Center" />

                                <StackPanel Grid.Column="1"
                                            Margin="10,0,14,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SyncIssueTitle}"
                                               Foreground="{Binding SyncIssueForeground}"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                    <TextBlock Margin="0,2,0,0"
                                               Text="{Binding SyncIssueText}"
                                               Foreground="#4B5563"
                                               FontSize="11.5"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <Button Grid.Column="2"
                                        MinWidth="64"
                                        Height="32"
                                        Padding="12,0"
                                        Command="{Binding SyncNowCommand}"
                                        Content="Retry"
                                        ToolTip="Retry usage sync"
                                        AutomationProperties.Name="Retry usage sync"
                                        Style="{DynamicResource LightButtonStyle}" />
                            </Grid>
                        </Border>

                        <ScrollViewer x:Name="ExpandedContentScrollViewer"
                                      Grid.Row="2"
                                      VerticalScrollBarVisibility="Hidden"
                                      HorizontalScrollBarVisibility="Disabled"
                                      ScrollChanged="ExpandedContentScrollViewer_ScrollChanged">
                        <StackPanel Margin="24,14,30,28">
                            <needsAttention:NeedsAttentionSection DataContext="{Binding NeedsAttention}"
                                                                   x:Name="NeedsAttentionSection"
                                                                   ReviewRequested="NeedsAttentionSection_ReviewRequested" />

                            <rateLimits:RateLimitsSection DataContext="{Binding RateLimits}"
                                                           x:Name="RateLimitsSection" />

                            <rateLimitsDaily:RateLimitsDailySection DataContext="{Binding RateLimitsDaily}"
                                                                     x:Name="WeeklyPaceSection" />

                            <usageTrend:UsageTrendSection DataContext="{Binding UsageTrend}"
                                                           x:Name="UsageTrendSection"
                                                           Visibility="{Binding DataContext.IsRunwayForecastVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                           SectionRequested="UsageTrendSection_SectionRequested" />

                            <resetCredits:ResetCreditsSection DataContext="{Binding ResetCreditsSection}"
                                                              x:Name="ResetCreditsSection" />

                            <accountUsage:AccountUsageSection DataContext="{Binding AccountUsage}"
                                                              x:Name="AccountUsageSection" />

                            <projectUsage:ProjectUsageSection DataContext="{Binding ProjectUsage}"
                                                              x:Name="ProjectUsageSection" />

                            <usageAttribution:UsageAttributionSection DataContext="{Binding UsageAttribution}"
                                                                        x:Name="BurnAnalysisSection" />

                            <dailyUsage:DailyUsageSection DataContext="{Binding DailyUsage}"
                                                          x:Name="DailyUsageSection" />
                        </StackPanel>
                    </ScrollViewer>
                    </Grid>
                </Grid>
        </Grid>
    </Border>
</Window>
