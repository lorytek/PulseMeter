<UserControl x:Class="PulseMeter.Slices.RateLimitsDaily.UI.RateLimitsDailySection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Border x:Name="RateLimitsDailyPanel"
                                    Margin="0,12,0,0"
                                    Padding="16"
                                    Style="{DynamicResource LightCardStyle}"
                                    Visibility="{Binding DataContext.IsRateLimitsDailyVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="WEEKLY PACE"
                                               Foreground="#111827"
                                               FontSize="20"
                                               FontWeight="Bold" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding RateLimitsDailySummaryText}"
                                               Foreground="#6B7280"
                                               FontSize="13" />
                                    <Border Margin="0,10,0,0"
                                            Padding="8,4"
                                            HorizontalAlignment="Left"
                                            Background="#FFF7ED"
                                            BorderBrush="#FED7AA"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Visibility="{Binding HasRateLimitsDailyWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="{Binding RateLimitsDailyWarningText}"
                                                   Foreground="#92400E"
                                                   FontSize="12" />
                                    </Border>

                                    <ItemsControl Margin="0,18,0,0"
                                                  ItemsSource="{Binding DailyRateLimitRows}"
                                                  Visibility="{Binding HasDailyRateLimitRows, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="7" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Width="92"
                                                            Margin="0,0,10,0"
                                                            HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding Label}"
                                                               Foreground="{Binding LabelBrush}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                    <Viewbox Width="82"
                                                             Height="82"
                                                             Margin="0,8,0,0"
                                                             HorizontalAlignment="Center">
                                                        <Grid Width="112"
                                                              Height="112">
                                                            <Path Stroke="#E5E7EB"
                                                                  StrokeThickness="7">
                                                                <Path.Data>
                                                                    <EllipseGeometry Center="56,56"
                                                                                     RadiusX="43"
                                                                                     RadiusY="43" />
                                                                </Path.Data>
                                                            </Path>
                                                            <Path Data="{Binding RingArcData}"
                                                                  Stroke="{Binding RingBrush}"
                                                                  StrokeThickness="7"
                                                                  StrokeStartLineCap="Round"
                                                                  StrokeEndLineCap="Round"
                                                                  StrokeLineJoin="Round" />
                                                            <TextBlock Text="{Binding RemainingPercentText}"
                                                                       Foreground="#111827"
                                                                       FontSize="24"
                                                                       FontWeight="Bold"
                                                                       TextAlignment="Center"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Viewbox>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
</UserControl>
